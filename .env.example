# Local Ollama (the provider appends paths to this base URL)
OLLAMA_BASE_URL=http://localhost:11434/api

# Models (must be pulled with `ollama pull`)

TUTOR_LLM_MODEL=qwen2.5:3b
TUTOR_EMBED_MODEL=nomic-embed-text
# nomic-embed-text outputs 768 dims. Change ONLY if you also change the embed model.
TUTOR_EMBED_DIM=768

# Vector + conversation storage
TUTOR_DB_URL=file:./tutor.db
TUTOR_INDEX=materials

# Retrieval tuning
TUTOR_TOPK=4
TUTOR_MIN_SCORE=0.3
